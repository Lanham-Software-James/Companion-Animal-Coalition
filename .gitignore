# Ignore everything by default
*

# Allow directories so Git can traverse
!*/

# Allow root-level project files (leading / anchors to repo root only)
!/.gitignore
!/README.md
!/docker-compose.yml
!/.env.example
!/.github/workflows/deploy.yml

# Allow wp-content hierarchy
!wp-content/
!wp-content/themes/
!wp-content/themes/cac-theme/
!wp-content/themes/cac-theme/**

# Allow cac-shelterluv plugin
!wp-content/plugins/
!wp-content/plugins/.gitignore
!wp-content/plugins/cac-shelterluv/
!wp-content/plugins/cac-shelterluv/**

# Ignore uploads and WordPress generated content
wp-content/uploads/
wp-content/cache/
wp-content/upgrade/

# Ignore node dependencies and build artifacts
node_modules/
dist/
build/

# Ignore OS and environment files
.DS_Store
Thumbs.db
*.log
.env
